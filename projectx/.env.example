# Copy to .env and fill in (never commit .env — it is gitignored).
#   cp projectx/.env.example projectx/.env
#
# Project Cursor load order: repo-root ../.env first, then this file (later overrides).
# You can put Telegram + Gateway vars only in ../../.env when using the standalone bundle.
#
# TopstepX (default in settings.yaml): https://api.topstepx.com → POST /api/Auth/loginKey
# Override host if needed:
# PROJECTX_API_BASE_URL=https://api.topstepx.com
# PROJECTX_RTC_USER_HUB=https://rtc.topstepx.com/hubs/user

PROJECTX_USERNAME=
PROJECTX_API_KEY=
PROJECTX_ACCOUNT_ID=
# List accounts (full JSON from API) after login:
#   python -m projectx.main --list-accounts
# Include inactive accounts if needed:
#   python -m projectx.main --list-accounts --list-accounts-include-inactive

# Optional: Telegram when Phoenix emits events (range sealed / new order signal).
# 1) Create a bot with @BotFather → PROJECTX_TELEGRAM_BOT_TOKEN=...
# 2) Your chat id (numeric) or @channelusername — e.g. from getUpdates after messaging the bot.
#    PROJECTX_TELEGRAM_CHAT_ID=123456789
# Aliases: TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID
# PROJECTX_TELEGRAM_BOT_TOKEN=
# PROJECTX_TELEGRAM_CHAT_ID=

# Optional: Discord (or compatible) webhook for Phoenix alerts on Windows/Linux VPS.
# Create a webhook in Discord → Server settings → Integrations → Webhooks.
# PROJECTX_WEBHOOK_URL=https://discord.com/api/webhooks/...
# (Alias: DISCORD_WEBHOOK_URL)
