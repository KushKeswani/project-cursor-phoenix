# =============================================================================
# Project Cursor — copy to ".env" in this folder (never commit .env)
# =============================================================================
# Setup: cp .env.example .env
#
# Load order: PROJECTX_DOTENV_PATH (if set) → ./.env → projectx/.env (later wins).
# Implemented in projectx.utils.helpers.load_dotenv_for_projectx()
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram — only two values needed for notifications / agent pings
# -----------------------------------------------------------------------------
# Bot token from @BotFather (looks like 123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
# — this is the TOKEN string, not the bot’s numeric user id.
PROJECTX_TELEGRAM_BOT_TOKEN=

# Your chat id — create your bot with @BotFather, message it once, then run:
#   python3 telegram/chat_id_helper.py
PROJECTX_TELEGRAM_CHAT_ID=

# Optional aliases (same meaning — use either PROJECTX_* or TELEGRAM_*)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Optional — scripts / tests / automation
# -----------------------------------------------------------------------------
# SKIP_TELEGRAM_SCRIPT_DONE=1
# PHOENIX_TEST_DATA_DIR=/absolute/path/to/Data-DataBento
# PROP_FARM_REPORTS_DIR=

# -----------------------------------------------------------------------------
# Optional — ProjectX Gateway (live trading, pull_bars). Omit if Telegram-only.
# -----------------------------------------------------------------------------
# PROJECTX_USERNAME=
# PROJECTX_API_KEY=
# PROJECTX_ACCOUNT_ID=
# PROJECTX_API_BASE_URL=https://api.topstepx.com
# PROJECTX_RTC_USER_HUB=https://rtc.topstepx.com/hubs/user

# -----------------------------------------------------------------------------
# Optional — Discord-style webhook; advanced dotenv override
# -----------------------------------------------------------------------------
# PROJECTX_WEBHOOK_URL=
# PROJECTX_DOTENV_PATH=
